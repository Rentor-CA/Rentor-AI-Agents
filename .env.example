# Claude API Key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Pika Developer Key (from pika.me/dev)
PIKA_DEV_KEY=dk_your-key-here

# Google Chat Configuration
GOOGLE_CHAT_PROJECT_ID=your-project-id
GOOGLE_CHAT_SERVICE_ACCOUNT_PATH=./service-account.json

# Server
PORT=8080

# Managed Agent IDs (populated after first setup, reused on restart)
MANAGED_AGENT_ID=
MANAGED_ENVIRONMENT_ID=
MANAGED_MEMORY_STORE_ID=
